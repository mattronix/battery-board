(footprint "BatterySpringContact_ConicalPCB_7mm"
	(version 20240108)
	(generator "claude")
	(generator_version "8.0")
	(layer "F.Cu")
	(descr "Conical PCB coil-spring battery contact. Real dims: base coil OD 7 mm, top coil OD 5 mm, free height 7 mm, wire 0.3 mm. Mount: solder the base coil flat to the 7.5 mm circular pad; cell end presses the 5 mm top coil and compresses axially. Single net. Hand-solder (NOT a JLCPCB pick-and-place part). Thin 0.3 mm wire = low current capacity - use for sense/monitor or low-current paths, not high pack discharge.")
	(tags "battery spring contact coil conical pcb 18650 axial touch-spring")
	(attr smd)
	(property "Reference" "BT**"
		(at 0 -5.5 0)
		(layer "F.SilkS")
		(effects (font (size 1 1) (thickness 0.15)))
	)
	(property "Value" "BatterySpringContact_ConicalPCB_7mm"
		(at 0 5.5 0)
		(layer "F.Fab")
		(effects (font (size 1 1) (thickness 0.15)))
	)
	(property "Footprint" "" (at 0 0 0) (layer "F.Fab") hide (effects (font (size 1.27 1.27))))
	(property "Datasheet" "" (at 0 0 0) (layer "F.Fab") hide (effects (font (size 1.27 1.27))))
	(property "Description" "" (at 0 0 0) (layer "F.Fab") hide (effects (font (size 1.27 1.27))))
	(fp_text user "${REFERENCE}"
		(at 0 0 0)
		(layer "F.Fab")
		(effects (font (size 1 1) (thickness 0.15)))
	)
	(pad "1" smd circle
		(at 0 0)
		(size 7.5 7.5)
		(layers "F.Cu" "F.Mask")
	)
	(fp_circle
		(center 0 0) (end 3.75 0)
		(stroke (width 0.12) (type default)) (fill none)
		(layer "F.Fab")
	)
	(fp_circle
		(center 0 0) (end 2.5 0)
		(stroke (width 0.1) (type default)) (fill none)
		(layer "F.Fab")
	)
	(fp_circle
		(center 0 0) (end 3.95 0)
		(stroke (width 0.12) (type default)) (fill none)
		(layer "F.SilkS")
	)
	(fp_circle
		(center 0 0) (end 4.25 0)
		(stroke (width 0.05) (type default)) (fill none)
		(layer "F.CrtYd")
	)
	(model "${KIPRJMOD}/BatterySpringContact_ConicalPCB_7mm.step"
		(offset (xyz 0 0 0))
		(scale (xyz 1 1 1))
		(rotate (xyz 0 0 0))
	)
)
