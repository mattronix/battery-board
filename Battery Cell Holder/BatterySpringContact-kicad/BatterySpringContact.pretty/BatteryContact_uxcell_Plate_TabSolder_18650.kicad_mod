(footprint "BatteryContact_uxcell_Plate_TabSolder_18650"
	(version 20240108)
	(generator "claude")
	(generator_version "8.0")
	(layer "F.Cu")
	(descr "uxcell-style stamped battery contact (18650/AA negative-to-positive conversion plate). Flat plate + solder tab with end hole; coil spring (neg) or conical button (pos) faces the cell. Mount = lay the tab flat on the copper pad and solder; the PTH at the tab end is a solder/wire anchor. ONE electrical net. NOMINAL dims for the ~16 mm 18650 plate variant - MEASURE your part and adjust (see README). NOT a JLCPCB pick-and-place part: hand-solder after assembly.")
	(tags "battery contact spring button plate tab solder 18650 AA uxcell conversion")
